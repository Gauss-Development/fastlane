# Copy to .env for local Compose runs. Use real secret values outside source control.

ENVIRONMENT=production
LOG_LEVEL=info

# Service-to-service transport:
# - mesh: app gRPC stays plaintext inside an mTLS mesh/private network
# - app_mtls: Go gRPC clients/servers use GRPC_TLS_* certificates directly
SERVICE_TRANSPORT_SECURITY=mesh
INTERNAL_HTTP_TRUST_MODE=private_network

GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

POSTGRES_USER_PASSWORD=replace-with-user-db-password
POSTGRES_POST_PASSWORD=replace-with-post-db-password
POSTGRES_NOTIFICATION_PASSWORD=replace-with-notification-db-password
POSTGRES_DESIGN_PASSWORD=
POSTGRES_CATALOG_PASSWORD=

# --- Object storage (MinIO) for design-service ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
S3_BUCKET=design-files
# Browser-reachable endpoint for presigned URLs (NOT the in-network minio:9000).
S3_PUBLIC_ENDPOINT=localhost:9000
PRESIGN_TTL=15m

REDIS_PASSWORD=replace-with-redis-password
REDIS_DB=0

RABBITMQ_USER=replace-with-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
RABBITMQ_VHOST=replace-with-rabbitmq-vhost
RABBITMQ_EXCHANGE=microservices_events
RABBITMQ_QUEUE_NOTIFICATIONS=post_notifications
RABBITMQ_DLX=blog_events.dlx
RABBITMQ_DLQ=post_notifications_dlq
RABBITMQ_DLQ_ROUTING_KEY=post.failed
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_DELAY=5
RABBITMQ_MAX_RETRIES=3

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URL=https://api.example.com/api/v1/auth/google/callback
GOOGLE_DEFAULT_WEB_REDIRECT_URI=https://app.example.com/auth/callback
GOOGLE_ALLOWED_WEB_REDIRECT_URIS=https://app.example.com/auth/callback
GOOGLE_ALLOWED_MOBILE_REDIRECT_URIS=myapp://auth/callback
GOOGLE_ALLOWED_DOMAINS=

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=168
JWT_ISSUER=auth-service

# --- Fiberlane: supplier magic-link tokens (separate signing key from JWT_SECRET) ---
# Optional: when unset, auth-service derives a dedicated key from JWT_SECRET.
MAGIC_LINK_JWT_SECRET=replace-with-at-least-32-random-characters
MAGIC_LINK_TTL_HOURS=336                # 14 days (GAU-249); magic link expires after this window

# --- Fiberlane: AI search (Claude tool-use + embeddings) ---
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5             # spec extraction + match explanations
VOYAGE_API_KEY=replace-with-voyage-api-key
OPENAI_API_KEY=replace-with-openai-api-key   # embeddings fallback only
# SEARCH_CACHE_TTL_HOURS=24                   # Redis TTL for spec/embedding/explanation cache

# --- Fiberlane: transactional email ---
# Optional: when unset, notification-service logs emails instead of sending.
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=Fiberlane <no-reply@fiberlane.app>
FRONTEND_URL=http://localhost:3000
# Consumer queue bindings (notification-service): post.*,rfq.created,quote.submitted
# RABBITMQ_NOTIFICATION_BINDINGS=post.*,rfq.created,quote.submitted

API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
POST_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
DESIGN_SERVICE_PORT=8086
CATALOG_SERVICE_PORT=8087

SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30
SERVER_IDLE_TIMEOUT=60
REQUEST_MAX_BODY_BYTES=1048576
TRUSTED_PROXIES=

RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20
RATE_LIMIT_ENABLED=true

CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSE_HEADERS=Content-Length,X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset
CORS_ALLOW_CREDENTIALS=true

AUTH_REFRESH_TOKEN_COOKIE=true
AUTH_REFRESH_TOKEN_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60
DB_MIGRATION_PATH=./migrations

NOTIFICATION_CLEANUP_DAYS=30
NOTIFICATION_BATCH_SIZE=100

# --- Monitoring (Prometheus + Grafana, started with `make infra-up`) ---
# Host ports (defaults match docker-compose). Prometheus scrapes app metrics on internal service ports;
# if you change HTTP ports below, update monitoring/prometheus/prometheus.yml targets.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# search-service exposes gRPC on 50054 and a separate metrics/health HTTP server (default 9095).
SEARCH_SERVICE_METRICS_HTTP_PORT=9095
