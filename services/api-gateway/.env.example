# api-gateway — copy to .env (`make setup`). Docker Compose injects most of these via
# its `environment:` block; these are for local `go run .` and to make the compose
# `env_file:` line resolve.

PORT=8080
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false

SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30
SERVER_IDLE_TIMEOUT=60

REDIS_URL=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

AUTH_SERVICE_URL=http://auth-service:8081
AUTH_SERVICE_GRPC_ADDR=auth-service:50051
USER_SERVICE_URL=http://user-service:8082
USER_SERVICE_GRPC_ADDR=user-service:50052
POST_SERVICE_URL=http://post-service:8083
POST_SERVICE_GRPC_ADDR=post-service:50053
SEARCH_SERVICE_GRPC_ADDR=search-service:50054
NOTIFICATION_SERVICE_URL=http://notification-service:8084

RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20
RATE_LIMIT_ENABLED=true

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSE_HEADERS=Content-Length,Access-Control-Allow-Origin,Access-Control-Allow-Headers,Content-Type,X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset
CORS_ALLOW_CREDENTIALS=true

AUTH_REFRESH_TOKEN_COOKIE=true
AUTH_REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_REFRESH_TOKEN_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

REQUEST_MAX_BODY_BYTES=1048576
TRUSTED_PROXIES=
