PORT=8088
GRPC_PORT=50055
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
INTERNAL_HTTP_TRUST_MODE=private_network
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

# Contains the DB password — treat as a secret.
# Overridden by docker-compose.yml environment block (uses POSTGRES_ORDER_PASSWORD from root .env).
DATABASE_URL=postgres://postgres:replace-with-order-db-password@postgres_order:5432/order_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60

# Overridden by docker-compose.yml environment block (uses RABBITMQ_* from root .env).
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=microservices_events
