# search-service — copy to .env (`make setup`). Docker Compose injects most of these
# via its `environment:` block; these are for local `go run .` and to make the compose
# `env_file:` line resolve.

GRPC_PORT=50054
METRICS_HTTP_PORT=9095
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

# Read-only access to the catalog DB (owned by post-service). Contains the DB password.
CATALOG_DATABASE_URL=postgres://postgres:@postgres_post:5432/postdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60

REDIS_URL=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# AI search (secrets — leave blank until you have them).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
VOYAGE_API_KEY=
OPENAI_API_KEY=
CACHE_TTL_HOURS=24
