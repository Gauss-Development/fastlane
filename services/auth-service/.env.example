# auth-service — copy to .env (`make setup`). Docker Compose injects most of these
# via its `environment:` block; the values here are for local `go run .` and to make
# the compose `env_file:` line resolve. Secrets are blank — fill them in.

PORT=8081
GRPC_PORT=50051
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
INTERNAL_HTTP_TRUST_MODE=private_network
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_IDLE_TIMEOUT=60

REDIS_URL=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

USER_SERVICE_GRPC_ADDR=user-service:50052

# Google OAuth (secrets — leave blank until you have them)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
GOOGLE_DEFAULT_WEB_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_ALLOWED_WEB_REDIRECT_URIS=http://localhost:3000/auth/callback
GOOGLE_ALLOWED_MOBILE_REDIRECT_URIS=myapp://auth/callback
GOOGLE_ALLOWED_DOMAINS=

# JWT (secret — must be at least 32 chars)
JWT_SECRET=
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=168
JWT_ISSUER=auth-service

# Supplier magic-link tokens. Optional: derived from JWT_SECRET when blank.
MAGIC_LINK_JWT_SECRET=
MAGIC_LINK_TTL_HOURS=336

FRONTEND_URL=http://localhost:3000
