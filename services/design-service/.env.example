# design-service — copy to .env (`make setup`). Docker Compose injects most of
# these via its `environment:` block; these are for local `go run .` and to make
# the compose `env_file:` line resolve. Enumerates exactly the vars config.go reads.

PORT=8086
GRPC_PORT=50056
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
INTERNAL_HTTP_TRUST_MODE=private_network
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

# Contains the DB password — treat as a secret.
DATABASE_URL=postgres://postgres:@postgres_design:5432/designdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60

# Object storage. S3_ENDPOINT must be BROWSER-reachable (presigned URLs are
# dialed by the client, not by design-service).
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=
S3_BUCKET=design-files
S3_USE_SSL=false
PRESIGN_TTL=15m
