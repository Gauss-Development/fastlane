# user-service — copy to .env (`make setup`). Docker Compose injects most of these
# via its `environment:` block; these are for local `go run .` and to make the
# compose `env_file:` line resolve.

PORT=8082
GRPC_PORT=50052
ENVIRONMENT=development
LOG_LEVEL=info

SERVICE_TRANSPORT_SECURITY=mesh
INTERNAL_HTTP_TRUST_MODE=private_network
GRPC_TLS_ENABLED=false
GRPC_TLS_CA_FILE=
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_REQUIRE_CLIENT_CERT=false
GRPC_REFLECTION_ENABLED=false

# Contains the DB password — treat as a secret.
DATABASE_URL=postgres://postgres:@postgres_user:5432/userdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=60
DB_MIGRATION_PATH=./migrations
